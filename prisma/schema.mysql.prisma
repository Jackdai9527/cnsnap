generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  passwordHash       String?
  googleId           String?
  name               String?
  avatarUrl          String?
  role               String              @default("user")
  status             String              @default("active")
  locale             String              @default("en")
  currency           String              @default("USD")
  referralCode       String              @unique
  referredBy         Int?
  walletBalance      Decimal             @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  addresses          Address[]
  orders             Order[]
  packages           Package[]
  payments           Payment[]
  walletTransactions WalletTransaction[]
  diyOrders          DiyOrder[]
  tickets            SupportTicket[]
  orderNotes         OrderNote[]
  uploadedMedia      MediaAsset[]        @relation("UploadedMedia")
  logs               OperationLog[]
  authAccounts       AuthAccount[]
}

model AuthAccount {
  id                Int     @id @default(autoincrement())
  userId            Int
  provider          String
  providerAccountId String
  type              String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthVerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id          Int      @id @default(autoincrement())
  userId      Int
  label       String   @default("Default")
  contactName String
  phone       String
  country     String
  state       String?
  city        String
  postalCode  String
  line1       String
  line2       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  orders      Order[]
}

model ProductCache {
  id                 Int         @id @default(autoincrement())
  platform           String
  sourceItemId       String
  sourceUrl          String
  title              String
  mainImage          String
  images             Json
  shopName           String?
  shopUrl            String?
  priceCny           Decimal
  priceUsd           Decimal
  skus               Json
  attributes         Json
  descriptionHtml    String?
  rawJson            Json
  cacheExpiredAt     DateTime
  isStorefrontActive Boolean     @default(false)
  isHomepageFeatured Boolean     @default(false)
  storefrontRank     Int         @default(0)
  importSource       String      @default("manual")
  sourceShopId       String?
  sourceShopName     String?
  sourceShopUrl      String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  orderItems         OrderItem[]

  @@unique([platform, sourceItemId])
  @@index([isStorefrontActive, storefrontRank, updatedAt])
  @@index([isHomepageFeatured, storefrontRank, updatedAt])
  @@index([sourceShopId])
}

model ValueAddedService {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  name             String
  description      String
  applicableRange  String?
  chargeStandard   String
  priceUsd         Decimal  @default(0)
  priceMode        String   @default("per_piece")
  serviceTime      String?
  buyerNotice      String?
  serviceGuarantee String?
  specialNote      String?
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model Order {
  id                   Int                 @id @default(autoincrement())
  orderNo              String              @unique
  userId               Int
  status               String              @default("pending_payment")
  orderSource          String              @default("url")
  orderStatus          String              @default("pending_payment")
  paymentStatus        String              @default("pending")
  purchaseStatus       String              @default("pending")
  warehouseStatus      String              @default("pending")
  packageStatus        String              @default("none")
  shippingPaymentStatus String             @default("none")
  shippingStatus       String              @default("none")
  riskStatus           String              @default("normal")
  refundStatus         String              @default("none")
  qcSharedWithCustomer Boolean             @default(false)
  qcSharedAt           DateTime?
  qcSharedBy           Int?
  qcCustomerConfirmed  Boolean             @default(false)
  qcCustomerConfirmedAt DateTime?
  qcCustomerConfirmedBy Int?
  destinationCountry   String?
  destinationCountryCode String?
  shippingAddressSnapshot Json?
  currency             String              @default("USD")
  subtotalCny          Decimal             @default(0)
  subtotalUsd          Decimal             @default(0)
  exchangeRate         Decimal             @default(0)
  serviceFeeUsd        Decimal             @default(0)
  domesticShippingUsd  Decimal             @default(0)
  valueAddedServicesUsd Decimal             @default(0)
  valueAddedServicesSnapshot Json?
  estimatedShippingUsd Decimal             @default(0)
  actualShippingUsd    Decimal             @default(0)
  discountUsd          Decimal             @default(0)
  refundUsd            Decimal             @default(0)
  totalUsd             Decimal             @default(0)
  paidUsd              Decimal             @default(0)
  unpaidUsd            Decimal             @default(0)
  itemCount            Int                 @default(0)
  totalQuantity        Int                 @default(0)
  assigneeId           Int?
  addressId            Int?
  preferredPaymentMethod String?
  userNote             String?
  adminNote            String?
  paidAt               DateTime?
  purchasedAt          DateTime?
  warehouseReceivedAt  DateTime?
  shippedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  user                 User                @relation(fields: [userId], references: [id])
  address              Address?            @relation(fields: [addressId], references: [id])
  items                OrderItem[]
  packages             Package[]
  payments             Payment[]
  walletTransactions   WalletTransaction[]
  notes                OrderNote[]
  mediaAssets          MediaAsset[]
  logs                 OperationLog[]

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([purchaseStatus])
  @@index([warehouseStatus])
  @@index([packageStatus])
  @@index([shippingPaymentStatus])
  @@index([shippingStatus])
  @@index([riskStatus])
  @@index([refundStatus])
  @@index([assigneeId])
  @@index([createdAt])
  @@index([updatedAt])
}

model OrderNote {
  id            Int      @id @default(autoincrement())
  orderId       Int
  type          String   @default("admin")
  content       String
  visibleToUser Boolean  @default(false)
  createdBy     Int?
  createdAt     DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  creator       User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([type])
  @@index([createdAt])
}

model OrderItem {
  id             Int           @id @default(autoincrement())
  orderId        Int
  productCacheId Int?
  platform       String
  sourceItemId   String
  sourceUrl      String
  title          String
  image          String
  skuId          String?
  skuText        String?
  priceCny       Decimal
  priceUsd       Decimal
  quantity       Int           @default(1)
  purchaseStatus String        @default("pending")
  createdAt      DateTime      @default(now())
  order          Order         @relation(fields: [orderId], references: [id])
  productCache   ProductCache? @relation(fields: [productCacheId], references: [id])
  packageItems   PackageItem[]
}

model Package {
  id                 Int                 @id @default(autoincrement())
  packageNo          String              @unique
  userId             Int
  orderId            Int?
  status             String              @default("pending")
  weightKg           Decimal             @default(0.5)
  lengthCm           Decimal?
  widthCm            Decimal?
  heightCm           Decimal?
  shippingChannelId  Int?
  shippingFeeUsd     Decimal             @default(0)
  trackingNumber     String?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id])
  order              Order?              @relation(fields: [orderId], references: [id])
  shippingChannel    ShippingChannel?    @relation(fields: [shippingChannelId], references: [id])
  items              PackageItem[]
  payments           Payment[]
  walletTransactions WalletTransaction[]
  mediaAssets        MediaAsset[]
}

model MediaAsset {
  id           Int      @id @default(autoincrement())
  filename     String
  originalName String
  url          String   @unique
  path         String   @unique
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  altText      String?
  caption      String?
  usage        String   @default("media_library")
  orderId      Int?
  packageId    Int?
  uploadedBy   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  package      Package? @relation(fields: [packageId], references: [id], onDelete: Cascade)
  uploader     User?    @relation("UploadedMedia", fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([usage])
  @@index([orderId])
  @@index([packageId])
  @@index([uploadedBy])
  @@index([createdAt])
  @@index([originalName])
}

model PackageItem {
  id          Int       @id @default(autoincrement())
  packageId   Int
  orderItemId Int
  quantity    Int       @default(1)
  package     Package   @relation(fields: [packageId], references: [id])
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
}

model Payment {
  id               Int      @id @default(autoincrement())
  paymentNo        String   @unique
  provider         String
  providerOrderNo  String?  @unique
  gatewayOrderNo   String?
  type             String   @default("product")
  userId           Int
  orderId          Int?
  packageId        Int?
  amount           Decimal
  currency         String   @default("USD")
  status           String   @default("pending")
  paymentMethod    String?
  redirectUrl      String?
  requestPayload   Json?
  responsePayload  Json?
  callbackPayload  Json?
  paidAt           DateTime?
  failedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
  order            Order?   @relation(fields: [orderId], references: [id])
  package          Package? @relation(fields: [packageId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([packageId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

model ShippingChannel {
  id                     Int       @id @default(autoincrement())
  name                   String
  code                   String    @unique
  sortOrder              Int       @default(0)
  supportedCountries     Json
  supportedCategories    Json
  forbiddenCategories    Json
  calculationRule         String    @default("chargeable_weight * freight_rmb_per_kg + handling_fee_rmb")
  notesHtml               String?
  trackingUrl             String?
  firstWeightKg          Decimal
  firstWeightFeeUsd      Decimal
  additionalWeightKg     Decimal
  additionalWeightFeeUsd Decimal
  volumeDivisor          Int       @default(5000)
  minWeightKg            Decimal   @default(0.5)
  deliveryTimeMin        Int
  deliveryTimeMax        Int
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  packages               Package[]
  rates                  ShippingRate[]
}

model ShippingRate {
  id              Int             @id @default(autoincrement())
  channelId       Int
  countryCode     String
  countryName     String
  freightRmbPerKg Decimal
  handlingFeeRmb  Decimal
  startWeightKg   Decimal
  maxWeightKg     Decimal
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  channel         ShippingChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, countryCode])
  @@index([countryCode])
}

model WalletTransaction {
  id               Int      @id @default(autoincrement())
  userId           Int
  type             String
  amount           Decimal
  currency         String   @default("USD")
  balanceAfter     Decimal
  relatedOrderId   Int?
  relatedPackageId Int?
  note             String?
  createdBy        Int?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
  order            Order?   @relation(fields: [relatedOrderId], references: [id])
  package          Package? @relation(fields: [relatedPackageId], references: [id])
}

model DiyOrder {
  id            Int      @id @default(autoincrement())
  userId        Int?
  productUrl    String
  productName   String?
  productImage  String?
  specification String?
  quantity      Int      @default(1)
  budgetUsd     Decimal?
  note          String?
  contactEmail  String
  status        String   @default("submitted")
  quoteProvided Boolean  @default(false)
  quoteUsd      Decimal?
  customerQuoteFeedback String?
  adminNote     String?
  purchaseItemName String?
  purchaseDate  DateTime?
  purchaseSize  String?
  purchaseWeightKg Decimal?
  productCostUsd Decimal?
  purchaseStatus String   @default("not_purchased")
  warehouseStatus String  @default("not_arrived")
  purchaseLink  String?
  shippingFeeUsd Decimal?
  serviceFeeUsd Decimal?
  convertedOrderId Int?
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id                 Int      @id @default(autoincrement())
  ticketNo           String   @unique
  userId             Int
  orderOrTrackingNo  String
  issueType          String
  problemDescription String
  status             String   @default("open")
  adminReply         String?
  repliedAt          DateTime?
  closedAt           DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

