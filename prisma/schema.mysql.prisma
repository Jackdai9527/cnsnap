model Setting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  label       String
  description String?
  updatedAt   DateTime @updatedAt
}

model ExchangeRateSnapshot {
  id                Int      @id @default(autoincrement())
  provider          String   @default("exchangerate-api")
  baseCode          String   @default("CNY")
  enabledCurrencies Json
  rates             Json
  result            String   @default("pending")
  status            String   @default("pending")
  error             String?
  fetchedAt         DateTime?
  providerUpdatedAt DateTime?
  providerNextAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([baseCode])
  @@index([fetchedAt])
}

model SensitiveKeyword {
  id        Int      @id @default(autoincrement())
  term      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpArticle {
  id           Int                      @id @default(autoincrement())
  slug         String                   @unique
  title        String
  category     String
  categoryKey  String?
  sortOrder    Int                      @default(0)
  excerpt      String
  content      String
  locale       String                   @default("en")
  isPublished  Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  descriptions HelpArticleDescription[]
}

model FaqItem {
  id           Int                  @id @default(autoincrement())
  categoryKey  String
  sortOrder    Int                  @default(0)
  status       String               @default("published")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  descriptions FaqItemDescription[]

  @@index([categoryKey, sortOrder])
  @@index([status, sortOrder])
}

model Page {
  id           Int               @id @default(autoincrement())
  slug         String            @unique
  title        String
  contentHtml  String
  isPublished  Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  descriptions PageDescription[]
}

model SeoSetting {
  id                     Int      @id @default(autoincrement())
  siteName               String
  defaultTitle           String
  titleTemplate          String
  defaultDescription     String
  defaultOgImage         String?
  defaultTwitterImage    String?
  defaultRobots          String   @default("index,follow")
  canonicalBaseUrl       String
  googleSiteVerification String?
  googleAnalyticsId      String?
  googleTagManagerId     String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model SeoPageMeta {
  id                 Int      @id @default(autoincrement())
  path               String   @unique
  pageType           String   @default("unknown")
  title              String
  description        String
  canonicalUrl       String?
  robots             String?
  ogTitle            String?
  ogDescription      String?
  ogImage            String?
  twitterTitle       String?
  twitterDescription String?
  twitterImage       String?
  structuredDataJson String?
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([pageType])
  @@index([enabled])
}

model SeoRobotsRule {
  id         Int      @id @default(autoincrement())
  pathPattern String
  ruleType   String
  userAgent  String   @default("*")
  enabled    Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled, sortOrder])
}

model SeoSitemapEntry {
  id              Int      @id @default(autoincrement())
  path            String   @unique
  changeFrequency String   @default("weekly")
  priority        Decimal  @default(0.5)
  lastModified    DateTime?
  enabled         Boolean  @default(true)
  sourceType      String   @default("service")
  sourceId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled])
  @@index([sourceType, sourceId])
}

model SeoLandingPage {
  id                 Int                         @id @default(autoincrement())
  title              String
  slug               String                      @unique
  type               String
  path               String                      @unique
  heroTitle          String
  heroSubtitle       String?
  content            String
  sectionsJson       String?
  faqJson            String?
  ctaText            String?
  ctaHref            String?
  status             String                      @default("draft")
  language           String                      @default("en")
  publishedAt        DateTime?
  seoTitle           String?
  seoDescription     String?
  canonicalUrl       String?
  robots             String                      @default("index,follow")
  ogTitle            String?
  ogDescription      String?
  ogImage            String?
  twitterTitle       String?
  twitterDescription String?
  twitterImage       String?
  structuredDataJson String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  descriptions       SeoLandingPageDescription[]

  @@index([type])
  @@index([status])
  @@index([language])
}

model SeoArticle {
  id           String                  @id
  categoryId   String
  authorId     String?
  coverImage   String?
  relatedArticleIds String?
  relatedLinksJson String?
  ctaType      String                  @default("none")
  status       String                  @default("draft")
  sortOrder    Int                     @default(0)
  publishedAt  DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  descriptions SeoArticleDescription[]

  @@index([status, publishedAt])
  @@index([categoryId, status])
}

model SeoArticleDescription {
  id                 Int      @id @default(autoincrement())
  articleId          String
  languageCode       String
  title              String
  slug               String
  excerpt            String
  content            String
  seoTitle           String?
  seoDescription     String?
  canonicalUrl       String?
  ogTitle            String?
  ogDescription      String?
  ogImage            String?
  twitterTitle       String?
  twitterDescription String?
  twitterImage       String?
  faqJson            String?
  structuredDataJson String?
  robots             String   @default("index,follow")
  readingTime        Int?
  tableOfContents    String?
  translationStatus  String   @default("draft")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  article            SeoArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, languageCode])
  @@index([languageCode, translationStatus])
  @@index([slug, languageCode])
}

model SeoLandingPageDescription {
  id                 Int             @id @default(autoincrement())
  landingPageId      Int
  languageCode       String
  path               String
  localizedPath      String?
  heroTitle          String
  heroSubtitle       String?
  content            String
  sectionsJson       String?
  faqJson            String?
  ctaText            String?
  ctaHref            String?
  seoTitle           String?
  seoDescription     String?
  canonicalUrl       String?
  robots             String          @default("index,follow")
  ogTitle            String?
  ogDescription      String?
  ogImage            String?
  twitterTitle       String?
  twitterDescription String?
  twitterImage       String?
  structuredDataJson String?
  translationStatus  String          @default("draft")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  landingPage        SeoLandingPage  @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@unique([landingPageId, languageCode])
  @@index([languageCode, translationStatus])
  @@index([path, languageCode])
}

model FrontendContentBlock {
  id           Int                               @id @default(autoincrement())
  blockKey     String                            @unique
  blockType    String
  groupKey     String?
  status       String                            @default("enabled")
  sortOrder    Int                               @default(0)
  createdAt    DateTime                          @default(now())
  updatedAt    DateTime                          @updatedAt
  descriptions FrontendContentBlockDescription[]

  @@index([groupKey, sortOrder])
  @@index([status, sortOrder])
}

model FrontendContentBlockDescription {
  id                Int                  @id @default(autoincrement())
  blockId           Int
  languageCode      String
  title             String?
  subtitle          String?
  content           String?
  shortContent      String?
  linkText          String?
  linkUrl           String?
  imageAlt          String?
  metaJson          String?
  translationStatus String               @default("draft")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  block             FrontendContentBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, languageCode])
  @@index([languageCode, translationStatus])
}

model HelpArticleDescription {
  id                Int         @id @default(autoincrement())
  helpArticleId     Int
  languageCode      String
  title             String
  slug              String
  summary           String?
  content           String
  seoTitle          String?
  seoDescription    String?
  faqJson           String?
  robots            String      @default("index,follow")
  translationStatus String      @default("draft")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  helpArticle       HelpArticle @relation(fields: [helpArticleId], references: [id], onDelete: Cascade)

  @@unique([helpArticleId, languageCode])
  @@index([languageCode, translationStatus])
  @@index([slug, languageCode])
}

model PageDescription {
  id                Int      @id @default(autoincrement())
  pageId            Int
  languageCode      String
  title             String
  slug              String
  contentHtml       String
  seoTitle          String?
  seoDescription    String?
  translationStatus String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  page              Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, languageCode])
  @@index([languageCode, translationStatus])
  @@index([slug, languageCode])
}

model FaqItemDescription {
  id                Int      @id @default(autoincrement())
  faqItemId         Int
  languageCode      String
  question          String
  answer            String
  translationStatus String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  faqItem           FaqItem  @relation(fields: [faqItemId], references: [id], onDelete: Cascade)

  @@unique([faqItemId, languageCode])
  @@index([languageCode, translationStatus])
}

model SeoRedirect {
  id         Int      @id @default(autoincrement())
  fromPath   String   @unique
  toPath     String
  statusCode Int      @default(301)
  enabled    Boolean  @default(true)
  hitCount   Int      @default(0)
  lastHitAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
  @@index([statusCode])
}

model EmailLog {
  id        Int      @id @default(autoincrement())
  to        String
  subject   String
  template  String
  status    String   @default("queued")
  error     String?
  createdAt DateTime @default(now())
}

model ApiLog {
  id          Int      @id @default(autoincrement())
  provider    String
  endpoint    String
  status      String
  latencyMs   Int      @default(0)
  requestMeta Json?
  error       String?
  createdAt   DateTime @default(now())
}

model OperationLog {
  id          Int      @id @default(autoincrement())
  actorId     Int?
  actorEmail  String?
  action      String
  targetType  String?
  targetId    String?
  targetLabel String?
  oldValue    Json?
  newValue    Json?
  ip          String?
  userAgent   String?
  message     String?
  orderId     Int?
  detail      String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorId], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id])

  @@index([actorId])
  @@index([actorEmail])
  @@index([action])
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
}
