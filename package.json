{
  "name": "haitao-agent-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "i18n:check": "tsx scripts/check-i18n-keys.ts",
    "status:check": "tsx scripts/check-order-status-sync.ts",
    "pricing:check": "tsx scripts/check-checkout-pricing.ts",
    "content:init": "tsx scripts/init-multilingual-content.ts",
    "prisma:sync:mysql-schema": "node scripts/sync-prisma-mysql-schema.mjs",
    "prisma:generate": "prisma generate",
    "prisma:generate:mysql": "npm run prisma:sync:mysql-schema && prisma generate --schema prisma/schema.mysql.prisma",
    "prisma:push": "prisma db push",
    "prisma:push:mysql": "npm run prisma:sync:mysql-schema && prisma db push --schema prisma/schema.mysql.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:mysql": "tsx prisma/seed.ts",
    "db:init": "rm -f prisma/dev.db && sqlite3 prisma/dev.db < prisma/init.sql && tsx prisma/seed.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "build:ci": "npm run prisma:generate && next build",
    "build:hostinger": "npm run prisma:generate:mysql && next build"
  },
  "dependencies": {
