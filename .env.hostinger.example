NODE_ENV="production"
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME"
APP_URL="https://your-domain.com"
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Keep uploads outside the build output so redeployments do not erase them.
STORAGE_ROOT="/home/your-hostinger-user/storage"
UPLOADS_BASE_URL="/uploads"

ONEBOUND_API_KEY=""
ONEBOUND_API_SECRET=""

AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

EMAIL_SERVER=""
EMAIL_FROM="CNSnap <no-reply@your-domain.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

PAYPAL_ENABLED="false"
PAYPAL_MODE="live"
PAYPAL_SANDBOX_CLIENT_ID=""
PAYPAL_SANDBOX_CLIENT_SECRET=""
PAYPAL_LIVE_CLIENT_ID=""
PAYPAL_LIVE_CLIENT_SECRET=""
PAYPAL_ADVANCED_CARD_ENABLED="false"
PAYPAL_BRAND_NAME="CNSnap"
PAYPAL_CURRENCY="USD"

# Safer production defaults: no demo users, no demo orders.
SEED_DEMO_DATA="false"
SEED_ADMIN_EMAIL="admin@your-domain.com"
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"
